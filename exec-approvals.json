{
    "version": 1,
    "defaults": {
        "security": "allowlist",
        "ask": "on-miss",
        "askFallback": "allowlist",
        "autoAllowSkills": true
    },
    "allowlist": [
        {
            "pattern": ".*skill.*",
            "comment": "Allow all skill-related commands"
        },
        {
            "pattern": ".*",
            "comment": "Allow all commands (fallback)"
        }
    ]
}
