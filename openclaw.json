{
    "agents": {
        "defaults": {
            "model": {
                "primary": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
                "fallbacks": ["qwen/qwen3.6-plus-preview:free"]
            },
            "imageModel": {
                "primary": "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
                "fallbacks": ["openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free", "huggingface-infer/Qwen/Qwen-VL-Chat"]
            },
            "models": {
                "openrouter/nvidia/nemotron-3-super-120b-a12b:free": {},
                "openrouter/nvidia/nemotron-nano-12b-v2-vl:free": {},
                "openrouter/qwen/qwen3.6-plus-preview:free": {},
                "stepfun/step-3.5-flash:free": {},
                "openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free": {}
            },
            "memorySearch": {
                "enabled": true,
                "provider": "openrouter",
                "model": "openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free"
            },
            "workspace": "${OPENCLAW_HOME}/workspace",
            "heartbeat": {
                "every": "120m",
                "model": "stepfun/step-3.5-flash:free",
                "ackMaxChars": 0,
                "target": "feishu",
                "to": "${FEISHU_CHAT_ID}"
            }
        }
    },
    "models": {
        "providers": {
            "openrouter": {
                "baseUrl": "https://openrouter.ai/api/v1",
                "apiKey": "${OPENROUTER_API_KEY}",
                "models": [
                    {
                        "id": "qwen/qwen3.6-plus-preview:free",
                        "name": "Qwen 3.6 Plus Preview",
                        "input": ["text"]
                    },
                    {
                        "id": "nvidia/nemotron-nano-12b-v2-vl:free",
                        "name": "LLama-Nemotron EmbedEmbedding",
                        "input": ["text", "image"]
                    },
                    {
                        "id": "nvidia/llama-nemotron-embed-vl-1b-v2:free",
                        "name": "Nvidia-Llamaamaemotron EmbedEmbedding"
                    },
                    {
                        "id": "stepfun/step-3.5-flash:free",
                        "name": "StepFun 3.5 Flash",
                        "input": ["text"]
                    },
                    {
                        "id": "nvidia/llama-nemotron-embed-vl-1b-v2:free",
                        "name": "Nvidia-Llamaamaemotron EmbedEmbedding"
                    }
                ]
            }
        }
    },
    "tools": {
        "web": {
            "search": {
                "provider": "gemini"
            }
        },
        "allow": ["group:automation", "exec", "group:fs", "web_search", "web_fetch"],
        "deny": ["browser"]
    },
    "commands": {
        "native": "auto",
        "nativeSkills": "auto",
        "restart": true,
        "ownerDisplay": "raw"
    },
    "session": {
        "dmScope": "per-channel-peer"
    },
    "channels": {
        "feishu": {
            "enabled": true,
            "appId": "${FEISHU_APP_ID}",
            "appSecret": "${FEISHU_APP_SECRET}",
            "connectionMode": "websocket",
            "domain": "lark",
            "groupPolicy": "disabled",
            "heartbeat": {
                "showOk": true
            }
        }
    },
    "gateway": {
        "port": 3000,
        "mode": "local",
        "bind": "lan",
        "controlUi": {
            "allowedOrigins": ["https://cyeamclaw.fly.dev"],
            "dangerouslyAllowHostHeaderOriginFallback": true
        },
        "auth": {
            "mode": "token",
            "token": "${OPENCLAW_GATEWAY_TOKEN}"
        },
        "tailscale": {
            "mode": "off",
            "resetOnExit": false
        }
    },
    "plugins": {
        "entries": {
            "feishu": {
                "enabled": true
            }
        }
    },
    "logging": {
        "level": "debug",
        "consoleLevel": "debug",
        "consoleStyle": "pretty",
        "redactSensitive": "tools",
        "redactPatterns": ["sk-.*"]
    }
}
