{
    "agents": {
        "defaults": {
            "model": {
                "primary": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
                "fallbacks": [
                    "qwen/qwen3.6-plus-preview:free",
                    "huggingface/deepseek-ai/DeepSeek-R1"
                ]
            },
            "imageModel": {
                "primary": "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
                "fallbacks": [
                    "openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free",
                    "huggingface-infer/Qwen/Qwen-VL-Chat"
                ]
            },
            "models": {
                "openrouter/minimax/minimax-m2.5:free": {},
                "openrouter/nvidia/nemotron-3-super-120b-a12b:free": {},
                "openrouter/nvidia/nemotron-nano-12b-v2-vl:free": {},
                "openrouter/qwen/qwen3.6-plus-preview:free": {},
                "huggingface/deepseek-ai/DeepSeek-R1": {},
                "huggingface-infer/Qwen/Qwen-VL-Chat": {},
                "openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free": {}
            },
            "memorySearch": {
                "enabled": true,
                "provider": "openrouter",
                "model": "openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free"
            },
            "workspace": "${OPENCLAW_HOME}/workspace",
            "heartbeat": {
                "every": "120m",
                "model": "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
                "ackMaxChars": 0,
                "target": "feishu",
                "to": "${FEISHU_CHAT_ID}"
            }
        }
    },
    "models": {
        "providers": {
            "huggingface-infer": {
                "baseUrl": "https://api-inference.huggingface.co/models",
                "api": "openai-completions",
                "apiKey": "${HUGGINGFACE_HUB_TOKEN}",
                "models": [
                    {
                        "id": "Qwen/Qwen-VL-Chat",
                        "name": "Qwen-VL-Chat",
                        "input": [
                            "image"
                        ]
                    }
                ]
            },
            "openrouter": {
                "baseUrl": "https://openrouter.ai/api/v1",
                "apiKey": "${OPENROUTER_API_KEY}",
                "models": [
                    {
                        "id": "minimax/minimax-m2.5:free",
                        "name": "Minimax M2.5",
                        "input": [
                            "text"
                        ]
                    },
                    {
                        "id": "qwen/qwen3.6-plus-preview:free",
                        "name": "Qwen 3.6 Plus Preview",
                        "input": [
                            "text"
                        ]
                    },
                    {
                        "id": "nvidia/nemotron-nano-12b-v2-vl:free",
                        "name": "LLama-Nemotron EmbedEmbedding",
                        "input": [
                            "text",
                            "image"
                        ]
                    },
                    {
                        "id": "nvidia/llama-nemotron-embed-vl-1b-v2:free",
                        "name": "Nvidia-Llamaamaemotron EmbedEmbedding"
                    }
                ]
            }
        }
    },
    "tools": {
        "web": {
            "search": {
                "provider": "gemini"
            }
        },
        "allow": [
            "group:automation",
            "exec",
            "group:fs",
            "web_search",
            "web_fetch"
        ],
        "deny": [
            "browser"
        ]
    },
    "commands": {
        "native": "auto",
        "nativeSkills": "auto",
        "restart": true,
        "ownerDisplay": "raw"
    },
    "session": {
        "dmScope": "per-channel-peer"
    },
    "channels": {
        "feishu": {
            "enabled": true,
            "appId": "${FEISHU_APP_ID}",
            "appSecret": "${FEISHU_APP_SECRET}",
            "connectionMode": "websocket",
            "domain": "lark",
            "groupPolicy": "disabled"
        }
    },
    "gateway": {
        "port": 3000,
        "mode": "local",
        "bind": "lan",
        "controlUi": {
            "allowedOrigins": [
                "https://cyeamclaw.fly.dev"
            ],
            "dangerouslyAllowHostHeaderOriginFallback": true
        },
        "auth": {
            "mode": "token",
            "token": "${OPENCLAW_GATEWAY_TOKEN}"
        },
        "tailscale": {
            "mode": "off",
            "resetOnExit": false
        }
    },
    "plugins": {
        "entries": {
            "feishu": {
                "enabled": true
            }
        }
    },
    "logging": {
        "level": "debug",
        "consoleLevel": "debug",
        "consoleStyle": "pretty",
        "redactSensitive": "tools",
        "redactPatterns": [
            "sk-.*"
        ]
    }
}